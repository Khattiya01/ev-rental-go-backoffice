                  "console.log('Vehicle unassigned from breach-test zone');"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"geofenceZoneId\": null\n}" },
            "url": { "raw": "{{baseUrl}}/api/vehicles/{{breachTestVehicleId}}", "host": ["{{baseUrl}}"], "path": ["api", "vehicles", "{{breachTestVehicleId}}"] }
          }
        },
        {
          "name": "Step 7: Cleanup — DELETE Breach Test Zone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204 No Content', () => pm.response.to.have.status(204));",
                  "console.log('✅ Breach test zone deleted — cleanup complete');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/geofences/{{breachTestZoneId}}", "host": ["{{baseUrl}}"], "path": ["api", "geofences", "{{breachTestZoneId}}"] }
          }
        }
      ]
    },

