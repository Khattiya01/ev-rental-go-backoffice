                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "const zone = pm.response.json();",
                  "pm.test('Has required zone fields', () => {",
                  "  pm.expect(zone).to.have.property('id');",
                  "  pm.expect(zone).to.have.property('name').that.eqls('Test Zone — ลาดพร้าว (Sprint 3 Test)');",
                  "  pm.expect(zone).to.have.property('coordinates').that.is.an('array').with.length.at.least(3);",
                  "  pm.expect(zone).to.have.property('active').that.is.true;",
                  "  pm.expect(zone).to.have.property('alertRecipients').that.is.an('array');",
                  "  pm.expect(zone).to.have.property('createdBy');",
                  "});",
                  "pm.test('Coordinates are valid lat/lng pairs', () => {",
                  "  zone.coordinates.forEach(pt => {",
                  "    pm.expect(pt).to.be.an('array').with.length(2);",
                  "    pm.expect(isFinite(pt[0])).to.be.true;",
                  "    pm.expect(isFinite(pt[1])).to.be.true;",
                  "  });",
                  "});",
                  "pm.environment.set('geofenceZoneId', zone.id);",
                  "console.log('Created geofence zone:', zone.id, '|', zone.name);"
