    {
      "name": "📍 Real-Time Positions — GET /api/vehicles/positions",
      "description": "ทดสอบ API ดึง GPS position ของทุกรถ — อ่านจาก Redis ก่อน ถ้า miss ตกไป DB",
      "item": [
        {
          "name": "GET All Vehicle Positions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('Each position has required fields', () => {",
                  "  pm.response.json().data.forEach(p => {",
                  "    pm.expect(p).to.have.property('vehicleId');",
                  "    pm.expect(p).to.have.property('lat').that.is.a('number');",
                  "    pm.expect(p).to.have.property('lng').that.is.a('number');",
                  "    pm.expect(p).to.have.property('soc').that.is.a('number');",
                  "    pm.expect(p).to.have.property('status');",
                  "    pm.expect(p).to.have.property('source');",
                  "    pm.expect(['redis','db']).to.include(p.source);",
                  "  });",
                  "});",
                  "pm.test('lat/lng are valid numbers (not NaN/Infinity)', () => {",
                  "  pm.response.json().data.forEach(p => {",
                  "    pm.expect(isFinite(p.lat)).to.be.true;",
                  "    pm.expect(isFinite(p.lng)).to.be.true;",
                  "  });",
                  "});",
                  "const data = pm.response.json().data;",
                  "const fromRedis = data.filter(p => p.source === 'redis').length;",
                  "const fromDb    = data.filter(p => p.source === 'db').length;",
                  "console.log(`Positions: ${data.length} total | ${fromRedis} from Redis | ${fromDb} from DB fallback`);",
                  "if (data.length > 0) {",
                  "  pm.environment.set('positionVehicleId', data[0].vehicleId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles/positions", "host": ["{{baseUrl}}"], "path": ["api", "vehicles", "positions"] }
          }
        },
        {
          "name": "GET Positions — Verify Redis source (sim must be running)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "const fromRedis = data.filter(p => p.source === 'redis');",
                  "// ⚠️ This test passes only when pnpm sim:gps is running",
                  "pm.test('At least one position sourced from Redis (requires sim:gps)', () => {",
                  "  if (fromRedis.length === 0) {",
                  "    console.warn('⚠️ No Redis positions found — start GPS simulator: pnpm sim:gps');",
                  "  }",
                  "  pm.expect(fromRedis.length).to.be.at.least(0); // soft check — log warning only",
                  "});",
                  "console.log(`Redis positions: ${fromRedis.length}/${data.length} — ${fromRedis.length === 0 ? 'sim NOT running' : 'sim OK ✅'}`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles/positions", "host": ["{{baseUrl}}"], "path": ["api", "vehicles", "positions"] }
          }
        },
        {
          "name": "[ERROR] GET Positions — No Session (expect 401)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 1) Clear the env token so the collection pre-request won't inject a valid cookie.",
                  "pm.environment.set('sessionToken', '');",
                  "// 2) Force an invalid cookie header for this request.",
                  "pm.request.headers.upsert({ key: 'Cookie', value: 'session=invalid-token-sprint3-test' });",
                  "// 3) Call logout to flush the Postman cookie jar — otherwise the jar",
                  "//    injects the real httpOnly session cookie alongside our invalid header.",
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "pm.sendRequest({ url: baseUrl + '/api/auth/logout', method: 'POST' }, function(err) {",
                  "  if (err) console.log('Pre-logout error (non-fatal):', err);",
                  "  // Re-apply after the async logout so Postman doesn't overwrite it.",
                  "  pm.request.headers.upsert({ key: 'Cookie', value: 'session=invalid-token-sprint3-test' });",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));",
                  "// Re-login to restore session for subsequent requests",
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "pm.sendRequest({",
                  "  url: baseUrl + '/api/auth/login',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ email: 'admin@evrentalgo.com', password: 'admin1234' }) }",
                  "}, function(err, res) {",
                  "  if (err) { console.log('Re-login error:', err); return; }",
                  "  const setCookie = res.headers.get('Set-Cookie');",
                  "  if (setCookie) {",
                  "    const m = setCookie.match(/session=([^;]+)/);",
                  "    if (m) pm.environment.set('sessionToken', m[1]);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles/positions", "host": ["{{baseUrl}}"], "path": ["api", "vehicles", "positions"] }
          }
        }
      ]
    },

    {
      "name": "🔔 Alerts Feed — GET /api/alerts",
      "description": "ทดสอบ Alerts API — รวม battery_low, payment_overdue, geofence_breach",
      "item": [
        {
          "name": "GET All Alerts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('Each alert has required fields', () => {",
                  "  pm.response.json().data.forEach(a => {",
                  "    pm.expect(a).to.have.property('id');",
                  "    pm.expect(a).to.have.property('type');",
                  "    pm.expect(a).to.have.property('message');",
                  "    pm.expect(a).to.have.property('severity');",
                  "    pm.expect(['critical','warning','info']).to.include(a.severity);",
                  "    pm.expect(['battery_low','payment_overdue','geofence_breach','payment_reminder']).to.include(a.type);",
                  "  });",
                  "});",
                  "const data = pm.response.json().data;",
                  "const byType = {};",
                  "data.forEach(a => { byType[a.type] = (byType[a.type] || 0) + 1; });",
                  "console.log('Alerts by type:', JSON.stringify(byType));",
                  "console.log('Total alerts:', data.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/alerts", "host": ["{{baseUrl}}"], "path": ["api", "alerts"] }
          }
        },
        {
          "name": "GET Alerts — Check for Geofence Breach entries",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const breachAlerts = pm.response.json().data.filter(a => a.type === 'geofence_breach');",
                  "// This is a soft check — breaches only exist if GPS sim ran a vehicle outside a zone",
                  "pm.test('Geofence breach alerts have href property (when present)', () => {",
                  "  breachAlerts.forEach(a => pm.expect(a).to.have.property('href'));",
                  "});",
                  "console.log(`Geofence breach alerts: ${breachAlerts.length}`);",
                  "if (breachAlerts.length > 0) {",
                  "  console.log('Sample breach:', JSON.stringify(breachAlerts[0], null, 2));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/alerts", "host": ["{{baseUrl}}"], "path": ["api", "alerts"] }
          }
        }
      ]
    },

