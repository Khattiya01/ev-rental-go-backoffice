{
  "name": "ev-rental-go-backoffice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env.local server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx --env-file=.env.local server.ts",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local db/seed.ts",
    "sim:gps": "tsx --env-file=.env.local scripts/gps-simulator.ts",
    "sonar": "sonar",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:test": "tsx --env-file=.env.test server.ts",
    "db:push:test": "drizzle-kit push --config=drizzle.config.test.ts",
    "db:seed:test": "tsx --env-file=.env.test db/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:gateway": "playwright test --config=playwright.gateway.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@types/leaflet-draw": "^1.0.13",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "flag-icons": "^7.5.0",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-intl": "^4.11.1",
    "postgres": "^3.4.9",
    "promptpay-qr": "^0.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-leaflet-draw": "^0.21.0",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "mqtt": "^5.15.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
